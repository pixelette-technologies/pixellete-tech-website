# Site URLs
# Both vars must match — no trailing slash on BASE_URL
NEXT_PUBLIC_SITE_URL=https://pixelettetech.com/
NEXT_PUBLIC_BASE_URL=https://pixelettetech.com

# Authentication (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# CMS (Contentful)
NEXT_PUBLIC_CONTENTFUL_SPACE_ID=your_contentful_space_id_here
NEXT_PUBLIC_CONTENTFUL_ACCESS_TOKEN=your_contentful_access_token_here

# Email Delivery (Resend)
# Get your API key from resend.com/api-keys
# Domain must be verified before sending from noreply@pixelettetech.com
RESEND_API_KEY=your_resend_api_key_here
