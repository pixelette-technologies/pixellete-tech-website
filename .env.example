# Site URLs
# Both vars must match — no trailing slash on BASE_URL
NEXT_PUBLIC_SITE_URL=https://pixelettetech.com/
NEXT_PUBLIC_BASE_URL=https://pixelettetech.com

# Authentication (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# CMS (Contentful)
NEXT_PUBLIC_CONTENTFUL_SPACE_ID=your_contentful_space_id_here
NEXT_PUBLIC_CONTENTFUL_ACCESS_TOKEN=your_contentful_access_token_here

# Email Delivery (Resend)
# Get your API key from resend.com/api-keys
# Domain must be verified before sending from noreply@pixelettetech.com
RESEND_API_KEY=your_resend_api_key_here

# Pix Chatbot — AI
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Pix Chatbot — Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJ_your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ_your_service_role_key

# Pix Chatbot — Notifications
SALES_EMAIL=sales@pixelettetech.com
FROM_EMAIL=pix@pixelettetech.com
WEEKLY_REPORT_EMAIL=asif@pixelettetech.com
PIX_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your_webhook

# Pix Chatbot — Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAA_your_site_key
TURNSTILE_SECRET_KEY=0x4AAA_your_secret_key

# Pix Chatbot — Feature Flags
PIX_TURNSTILE_ENABLED=true
PIX_RATE_LIMIT_ENABLED=true
PIX_DEV_ENDPOINTS_ENABLED=false

# Pix Chatbot — Cron
# CRON_SECRET — secures the weekly report endpoint
# Generate a random 32-character string for production
CRON_SECRET=your_random_32_char_string_here
